# =============================================================================
# template.env — Azure DevOps Sync Environment Variables
# =============================================================================
#
# Copy this file to the project root as .env and fill in your values:
#
#   cp .claude/skills/azure-devops-sync/templates/template.env .env
#
# Variables are loaded automatically by all bash scripts via _env-loader.sh.
# PowerShell scripts read AZURE_DEVOPS_EXT_PAT from the environment directly;
# set it before running:
#
#   $env:AZURE_DEVOPS_EXT_PAT = "your-pat-here"
#
# IMPORTANT: Never commit .env to source control (.env is in .gitignore).
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Personal Access Token for Azure DevOps REST API / CLI
# Create at: https://dev.azure.com/{org}/_usersSettings/tokens
# Scopes needed: Work Items (Read & Write), Project and Team (Read)
# ---------------------------------------------------------------------------
AZURE_DEVOPS_EXT_PAT=

# ---------------------------------------------------------------------------
# OPTIONAL — Override defaults if your project differs
# ---------------------------------------------------------------------------

# Azure DevOps organization URL
# AZURE_DEVOPS_ORG=https://dev.azure.com/<your-org>

# Azure DevOps project name
# AZURE_DEVOPS_PROJECT=<your-project>

# Default Area Path for new work items (defaults to project name)
# AZURE_DEVOPS_AREA_PATH=<your-project>

# Default root Iteration Path (defaults to project name)
# AZURE_DEVOPS_ITERATION=<your-project>

# Tag applied to ALL work items (default: Bolt Framework)
# AZURE_DEVOPS_REQUIRED_TAG=Bolt Framework
