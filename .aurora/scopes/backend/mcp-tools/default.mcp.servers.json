{
    "servers": {
        "github": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@github/github-mcp-server@latest"
            ]
        },
        "context7": {
            "type": "http",
            "url": "https://mcp.context7.com/mcp"
        },
        "dbhub": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@bytebase/dbhub@latest",
                "--transport",
                "stdio"
            ],
            "env": {
                "DBHUB_DSN": "${input:dbhub-dsn}"
            }
        },
        "mongoDb": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "mongodb-mcp-server@latest",
                "--readOnly"
            ],
            "env": {
                "MDB_MCP_CONNECTION_STRING": "${input:mongodb-connection-string}"
            }
        }
    },
    "inputs": [
        {
            "type": "promptString",
            "id": "dbhub-dsn",
            "description": "Database DSN for DBHub",
            "password": true
        },
        {
            "type": "promptString",
            "id": "mongodb-connection-string",
            "description": "MongoDB connection string",
            "password": true
        }
    ]
}
