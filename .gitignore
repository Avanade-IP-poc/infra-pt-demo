# =============================================================================
# AURORA-IA / AI-DLC - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Temporary / Working Directories
# -----------------------------------------------------------------------------
temporal/
temp/
tmp/
.tmp/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
vendor/
.pnp/
.pnp.js
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
.env/
ENV/

# Bolt Framework Python Virtual Environment
.bolt-venv/

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
target/
*.egg-info/
*.egg
.eggs/
*.whl

# -----------------------------------------------------------------------------
# Test / Coverage
# -----------------------------------------------------------------------------
coverage/
.coverage
htmlcov/
.nyc_output/
*.lcov
.pytest_cache/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Mutation Testing (Stryker)
# -----------------------------------------------------------------------------
.stryker-tmp/
reports/mutation/
stryker.log

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
.secrets/

# -----------------------------------------------------------------------------
# Package Manager Locks (optional - uncomment if needed)
# -----------------------------------------------------------------------------
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.backup
*.orig
.cache/
.parcel-cache/
.turbo/
